# Copy to .env and fill in. Everything defaults to offline (no model calls).
LITNAV_DB_PATH=data/runtime/litnav.sqlite

# ── Model access ───────────────────────────────────────────────────────────
# Provider: none (default, fully offline) | openai | qwen
LITNAV_LLM_PROVIDER=none

# Your API key (or set OPENAI_API_KEY instead). Never commit a real key.
LITNAV_LLM_API_KEY=

# Models (used when provider != none). Defaults shown.
LITNAV_LLM_MODEL=gpt-4o-mini
LITNAV_EMBED_MODEL=text-embedding-3-small

# Optional: override the OpenAI base URL (Azure / proxy / self-hosted). Leave unset for OpenAI.
# LITNAV_LLM_BASE_URL=
