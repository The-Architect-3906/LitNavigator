# Copy to .env and fill in. Everything defaults to offline (no model calls).
LITNAV_DB_PATH=data/runtime/litnav.sqlite

# ── Model access (any OpenAI-compatible provider — not limited to OpenAI/Qwen) ─
# Provider: none (default, fully offline) | openai | qwen | deepseek | groq |
#           openrouter | together | ollama | <anything else, via LITNAV_LLM_BASE_URL below>
LITNAV_LLM_PROVIDER=none

# Your API key (or set OPENAI_API_KEY instead). Never commit a real key.
# For a local server (e.g. Ollama) any non-empty placeholder works.
LITNAV_LLM_API_KEY=

# Models, per tier. Defaults are OpenAI; override to use another provider's models.
#   cheap    = the default / most-used chat model
#   frontier = the stronger model for hard judgements (edge verify, uncertain grading)
# Single-model providers: set both to the same model.
LITNAV_LLM_MODEL=gpt-4o-mini
LITNAV_LLM_MODEL_FRONTIER=gpt-4o
LITNAV_EMBED_MODEL=text-embedding-3-small

# Endpoint. Leave unset for OpenAI or a named preset above; set it for ANY other
# OpenAI-compatible endpoint (Azure / vLLM / a proxy / a self-hosted server).
# LITNAV_LLM_BASE_URL=

# Optional: blended $/1k-token rates so cost metering stays accurate on non-OpenAI pricing.
# LITNAV_LLM_USD_PER_1K=0.0004
# LITNAV_LLM_USD_PER_1K_FRONTIER=0.005
# LITNAV_EMBED_USD_PER_1K=0.00002

# ── Retrieval ────────────────────────────────────────────────────────────────
# Opt-in semantic retrieval: set to "vector" to rank chunks by embedding cosine
# similarity (build the index first: python -m litnav.retrieval.vector). Unset =
# concept-tagged retrieval (the default, fully offline).
# LITNAV_RETRIEVAL=vector
